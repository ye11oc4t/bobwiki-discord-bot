# Discord 채널 웹훅 URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# BoB Wiki MediaWiki API
WIKI_API_URL=https://kitribob.wiki/api.php
WIKI_BASE_URL=https://kitribob.wiki/wiki/

# 몇 초마다 최근바뀜 확인할지
POLL_INTERVAL=60

# 한 번에 가져올 최근바뀜 개수
RCLIMIT=20

# 0 = 일반 문서만 감시
# 전체 namespace 감시하려면 빈 값으로 설정
RC_NAMESPACE=0

# edit|new = 수정 + 새 문서
# new = 새 문서만
# edit = 수정만
RC_TYPE=edit|new

# Railway Volume을 /data에 붙이면 이 값을 /data/state.json 으로 설정
# Volume 없이 테스트할 때는 state.json으로 둬도 됨
STATE_FILE=state.json

# 첫 실행 때 이미 존재하는 최근바뀜도 전송할지 여부
SEND_EXISTING_ON_FIRST_RUN=false

# User-Agent
USER_AGENT=bob-wiki-discord-watcher/1.0
